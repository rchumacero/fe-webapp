{
  "name": "kplian-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "pages:build": "npx turbo run pages:build --filter=web"
  },
  "devDependencies": {
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "npm@10.5.0",
  "overrides": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native-safe-area-context": "~5.6.0"
  },
  "optionalDependencies": {
    "lightningcss": "^1.29.1",
    "@next/swc-linux-x64-gnu": "15.1.7",
    "@next/swc-linux-x64-musl": "15.1.7"
  }
}
