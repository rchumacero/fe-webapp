{
  "name": "kplian-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "npm@10.5.0",
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native-safe-area-context": "~5.6.0"
  }
}
